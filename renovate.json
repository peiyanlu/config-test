{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "schedule:weekly",
    "group:allNonMajor"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "rebase",
  "timezone": "Asia/Shanghai",
  "labels": ["dependencies"],
  "ignorePaths": [
    "**/test/**",
    "**/*-lock.*"
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchPackageNames": ["@types/node", "typescript", "vite", "node"],
      "enabled": false
    }
  ]
}
